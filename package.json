{
  "name": "agent-cli-ui-wrapper",
  "version": "0.1.0",
  "description": "Thin UI wrapper over GitHub Copilot CLI with dictation support",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit",
    "rebuild": "electron-rebuild -f -w node-pty",
    "package": "electron-vite build && electron-builder"
  },
  "keywords": [
    "copilot",
    "cli",
    "electron",
    "dictation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron-store": "^11.0.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "node-pty": "^1.1.0",
    "sass": "^1.99.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6"
  }
}
